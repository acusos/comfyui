###############################################################################
venv/
.venv/
env/

###############################################################################
# IDEs
###############################################################################
.vscode/
.idea/

###############################################################################
# Operating System
###############################################################################
.DS_Store
Thumbs.db

###############################################################################
# Logs
###############################################################################
*.log

###############################################################################
# Temporary Files
###############################################################################
tmp/
temp/
.cache/

###############################################################################
# Hugging Face
###############################################################################
huggingface/
hf_home/

###############################################################################
# Models (never store these in Git)
###############################################################################
*.safetensors
*.gguf
*.ckpt
*.pt
*.pth
*.bin
*.onnx

###############################################################################
# LoRA / Embeddings / VAE archives
###############################################################################
*.safetensors.index.json

###############################################################################
# Generated Images
###############################################################################
*.png
*.jpg
*.jpeg
*.webp
*.bmp
*.tif
*.tiff
*.exr

###############################################################################
# Generated Video
###############################################################################
*.mp4
*.mov
*.avi
*.mkv
*.webm
*.gif

###############################################################################
# Audio
###############################################################################
*.wav
*.mp3
*.flac
*.ogg

###############################################################################
# Archives
###############################################################################
*.zip
*.7z
*.rar
*.tar
*.gz
*.xz

###############################################################################
# NVIDIA / Profiling
###############################################################################
*.qdrep
*.nsys-rep

###############################################################################
# ComfyUI Runtime
###############################################################################
input/
output/
outputs/
temp/

###############################################################################
# Benchmarks (keep summaries, ignore raw captures)
###############################################################################
benchmarks/raw/

###############################################################################
